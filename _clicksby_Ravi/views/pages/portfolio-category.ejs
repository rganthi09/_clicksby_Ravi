<h2>Portfolio - <%= category.replace('-', ' ') %></h2>

<div class="row">
  <% if (!images || images.length === 0) { %>
    <div class="col-12">No images yet.</div>
  <% } else { %>
    <% images.forEach(img => { %>
      <div class="col-6 col-md-4 col-lg-3 mb-3">
        <div class="card">
          <img src="<%= img %>" class="card-img-top img-fluid" alt="portfolio image">
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
