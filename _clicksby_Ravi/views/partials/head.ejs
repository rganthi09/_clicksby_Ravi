<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= title %> - <%= process.env.SITE_TITLE || '_Clicksby_Ravi' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/lightbox.css">
    <!-- Load a free display font as a Wakanda-style sample (Audiowide, Google Fonts) -->
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&display=swap" rel="stylesheet">
    <script>
      // feature-detect font loading and add a class for fallbacks
      (function(){
        try {
          if (document && document.fonts && document.fonts.check) {
            // treat either a bundled WakandaCustom or the Google 'Audiowide' font as acceptable
            var wakandaOk = document.fonts.check('12px "WakandaCustom"');
            var audiowideOk = document.fonts.check('12px "Audiowide"');
            if (!wakandaOk && !audiowideOk) {
              document.documentElement.classList.add('no-wakanda-font');
            }
          }
        } catch(e) { /* ignore */ }
      })();
    </script>
  </head>
  <body>
