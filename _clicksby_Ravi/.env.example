# Rename to .env and fill values
PORT=3000
SITE_TITLE="Clicks by Ravi"

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# NOTE: If you don't configure Cloudinary (leave the values blank),
# the app will fall back to serving images from the local
# `public/uploads` directory for development/testing.

# SMTP (for Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=youruser@example.com
SMTP_PASS=yourpassword
MAIL_FROM="Clicks by Ravi <no-reply@example.com>"
MAIL_TO=your-email@example.com

# Optional simple admin upload secret (keep private)
UPLOAD_SECRET=change-me
